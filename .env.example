# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/signal_db

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── News: NewsAPI (fallback, free, last 30 days only) ─────
# Get key at: https://newsapi.org/register
NEWSAPI_KEY=your-newsapi-key

# ── News + Sentiment: Alpha Vantage (recommended, free) ───
# Get key at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 calls/day — includes historical news + built-in sentiment scores
# Each ticker enrichment uses 2 calls (2 years history).
# Leave blank to fall back to NewsAPI + FinBERT.
ALPHAVANTAGE_KEY=your-alphavantage-key

# ── FinBERT via HuggingFace (fallback when AV not set) ────
# Get token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your-huggingface-token
HF_FINBERT_URL=https://router.huggingface.co/hf-inference/models/ProsusAI/finbert
NEWS_FETCH_LIMIT=10

# ── App ───────────────────────────────────────────────────
APP_NAME=Trading Signal API
APP_VERSION=2.0.0
APP_DEBUG=False
