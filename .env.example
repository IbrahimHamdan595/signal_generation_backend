# ── MongoDB ───────────────────────────────────────────────
MONGODB_URL=mongodb+srv://your-user:your-password@your-cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=trading_db

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Phase 2: Sentiment Pipeline ───────────────────────────
NEWSAPI_KEY=your-newsapi-key
HF_API_TOKEN=your-huggingface-token
HF_FINBERT_URL=https://router.huggingface.co/hf-inference/models/ProsusAI/finbert
NEWS_FETCH_LIMIT=10

# ── App ───────────────────────────────────────────────────
APP_NAME=Trading Signal API
APP_VERSION=1.0.0
DEBUG=False
